# Copy this file to .env.local for local development
# .env.local is gitignored — never commit real keys

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude model override ───────────────────────────────────────────
# Default is claude-haiku-4-5-20251001 (fast + cheap)
# Use claude-sonnet-4-6 for more capable responses
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Optional: Twilio SMS alerts ───────────────────────────────────────────────
# Get these from console.twilio.com
# All numbers must be E.164 format: +1XXXXXXXXXX
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+12085550000
ALERT_PHONE_NUMBER=+12085559999

# ── Optional: Override system prompt ─────────────────────────────────────────
# Useful for testing a client's prompt locally without editing api/chat.js
# SYSTEM_PROMPT=You are the AI receptionist for...
