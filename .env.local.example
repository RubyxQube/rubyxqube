# Copy this file to .env.local for local development
# .env.local is gitignored — never commit real keys

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude model override ───────────────────────────────────────────
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── ntfy.sh push — Boyd's phone (free) ────────────────────────────────────────
# Install the ntfy app, subscribe to https://ntfy.sh/<your-topic>
# Use a random string so the topic isn't guessable
NTFY_TOPIC=rxq-alerts-changeme

# ── TextBelt SMS — client's phone (~$0.01/text, no A2P needed) ────────────────
# Buy credits at textbelt.com — no subscription, no auto-recharge
# Use key "textbelt" for 1 free test text per day
TEXTBELT_KEY=textbelt
ALERT_PHONE_NUMBER=+12085559999

# ── Resend email — free tier ──────────────────────────────────────────────────
RESEND_API_KEY=re_...
ALERT_EMAIL=boyd@rubyxqube.com
# FROM_EMAIL=alerts@rubyxqube.com   # use a verified domain in prod

# ── Notion CRM (optional) ─────────────────────────────────────────────────────
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=...

# ── Override system prompt (for local testing) ────────────────────────────────
# SYSTEM_PROMPT=You are the AI receptionist for...
